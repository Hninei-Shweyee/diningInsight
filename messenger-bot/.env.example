# Facebook Page Access Token
# Get this from Facebook Developer Console > Your App > Messenger > Settings > Access Tokens
PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here

# Verify Token (you choose this yourself — must match what you enter in Facebook Developer Console)
VERIFY_TOKEN=your_custom_verify_token_here

# App Secret
# Get this from Facebook Developer Console > Your App > Settings > Basic > App Secret
APP_SECRET=your_facebook_app_secret_here

# Port for the Express server
PORT=3000

# URL of your FastAPI backend (change when deploying)
FASTAPI_URL=http://localhost:8000
